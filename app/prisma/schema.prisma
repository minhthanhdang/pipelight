generator client {
  provider = "prisma-client-js"
  output   = "../node_modules/.prisma/client"
}

datasource db {
  provider = "postgresql"
}

model User {
  id                String      @id @default(cuid())
  name              String?
  email             String      @unique
  emailVerified     DateTime?
  image             String?
  password          String?
  fivetranApiKey    String?     @map("fivetran_api_key")
  fivetranApiSecret String?     @map("fivetran_api_secret")
  createdAt         DateTime    @default(now())
  updatedAt         DateTime    @updatedAt
  accounts          Account[]
  sessions          Session[]
  chatSessions      ChatSession[]
  connectors        Connector[]
  syncEvents        SyncEvent[]
  aiActions         AIAction[]
  syncAudits        SyncAudit[]
  syncSummaries     SyncSummary[]
  agentConfig       AgentConfig?
}

model Account {
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
  user              User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([provider, providerAccountId])
}

model Session {
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model VerificationToken {
  identifier String
  token      String
  expires    DateTime

  @@id([identifier, token])
}

model ChatSession {
  id           String        @id @default(cuid())
  userId       String        @map("user_id")
  adkSessionId String        @map("adk_session_id")
  agentType    String        @default("main") @map("agent_type")
  title        String        @default("New chat")
  createdAt    DateTime      @default(now()) @map("created_at")
  updatedAt    DateTime      @updatedAt @map("updated_at")
  user         User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  messages     ChatMessage[]

  @@map("chat_sessions")
}

model ChatMessage {
  id        String      @id @default(cuid())
  sessionId String      @map("session_id")
  role      String
  content   String
  createdAt DateTime    @default(now()) @map("created_at")
  session   ChatSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  @@map("chat_messages")
}

model Connector {
  id                   String    @default(cuid())
  fivetranId           String    @map("fivetran_id")
  service              String
  paused               Boolean   @default(false)
  syncFrequency        Int       @map("sync_frequency")
  schemaChangeHandling String    @map("schema_change_handling")
  setupState           String    @map("setup_state")
  syncState            String    @map("sync_state")
  succeededAt          DateTime? @map("succeeded_at")
  failedAt             DateTime? @map("failed_at")
  schemaPrefix         String?   @map("schema_prefix")
  groupId              String?   @map("group_id")
  destinationService   String?   @map("destination_service")
  lastSyncedFromApi    DateTime  @default(now()) @map("last_synced_from_api")
  createdAt            DateTime  @default(now()) @map("created_at")
  updatedAt            DateTime  @updatedAt @map("updated_at")
  userId               String    @map("user_id")
  user                 User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([id])
  @@unique([fivetranId, userId])
  @@map("connectors")
}

model SyncEvent {
  id           String    @id @default(cuid())
  connectorId  String    @map("connector_id")
  fivetranId   String    @map("fivetran_id")
  status       String
  auditStatus  String    @default("pending") @map("audit_status")
  startedAt    DateTime  @map("started_at")
  completedAt  DateTime? @map("completed_at")
  rowsSynced   Int?      @map("rows_synced")
  syncType     String?   @map("sync_type")
  syncMetrics  Json?     @map("sync_metrics")
  errorMessage String?   @map("error_message")
  snapshotData Json?     @map("snapshot_data")
  userId       String    @map("user_id")
  user         User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt    DateTime  @default(now()) @map("created_at")

  audits       SyncAudit[]

  @@index([userId, startedAt])
  @@index([fivetranId, startedAt])
  @@map("sync_events")
}


model AIAction {
  id           String   @id @default(cuid())
  connectorId  String?  @map("connector_id")
  fivetranId   String?  @map("fivetran_id")
  action       String
  toolName     String   @map("tool_name")
  input        String?
  output       String?
  approved     Boolean  @default(true)
  userId       String   @map("user_id")
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt    DateTime @default(now()) @map("created_at")

  @@index([userId, createdAt])
  @@map("ai_actions")
}

model SyncAudit {
  id          String    @id @default(cuid())
  syncEventId String    @map("sync_event_id")
  connectorId String    @map("connector_id")
  fivetranId  String    @map("fivetran_id")
  judgement    String
  directCause String    @map("direct_cause")
  analysis    String
  suggestions String
  userId      String    @map("user_id")
  createdAt   DateTime  @default(now()) @map("created_at")
  syncEvent   SyncEvent @relation(fields: [syncEventId], references: [id], onDelete: Cascade)
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
  @@index([judgement])
  @@map("sync_audits")
}

model AgentConfig {
  id                String   @id @default(cuid())
  userId            String   @unique @map("user_id")
  model             String   @default("gemini-2.5-flash")
  temperature       Float?
  topP              Float?
  thinkingLevel     String?  @map("thinking_level")
  customInstruction String?  @map("custom_instruction")
  createdAt         DateTime @default(now()) @map("created_at")
  updatedAt         DateTime @updatedAt @map("updated_at")
  user              User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("agent_configs")
}

model SyncSummary {
  id            String   @id @default(cuid())
  userId        String   @map("user_id")
  connectorId   String?  @map("connector_id")
  fivetranId    String?  @map("fivetran_id")
  periodStart   DateTime @map("period_start")
  periodEnd     DateTime @map("period_end")
  periodLabel   String   @map("period_label")
  summary       String
  stats         Json?
  createdAt     DateTime @default(now()) @map("created_at")
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
  @@index([userId, connectorId, periodLabel])
  @@map("sync_summaries")
}
